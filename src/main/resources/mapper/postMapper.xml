<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.kotlinStudyServer.mapper.PostMapper">

    <select id="getListALL" resultType="com.example.kotlinStudyServer.model.Post">
        SELECT id
             , user_id as userId
             , title
             , body
             , created_at as createdAt
        FROM posts
        ORDER BY id ASC
    </select>

    <select id="getOneOfList" resultType="com.example.kotlinStudyServer.model.Post">
        SELECT id
             , user_id as userId
             , title
             , body
            ,created_at as createdAt
        FROM posts
        WHERE 1=1
            <if test="id != '' and id != null and id != 'ALL'">
            AND id = #{id}
            </if>
    </select>

    <select id="getListCount" resultType="com.example.kotlinStudyServer.model.Post">
        select count(*) as maxCount
        from posts
    </select>

</mapper>